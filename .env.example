# .env.example
# Variables d'environnement pour l'application backend

# Configuration du serveur
PORT=5001

# MongoDB
# Exemple pour MongoDB local : mongodb://localhost:27017/wejoy
# Exemple pour MongoDB Atlas : mongodb+srv://username:password@cluster.mongodb.net/wejoy
MONGO_URI=

# Sécurité
# Générer un secret fort (au moins 32 caractères)
JWT_SECRET=

# Autres configurations possibles (optionnel)
# NODE_ENV=development
# API_URL=http://localhost:5000
# CLIENT_URL=http://localhost:3000